    {
      "name": "recognition_register_face",
      "description": "Register a student's face embedding from an image. Supports multi-angle registration (front, left, right). Detects duplicate faces across students.",
      "category": "recognition",
      "inputSchema": {
        "type": "object",
        "properties": {
          "student_id": {
            "type": "string",
            "description": "Student UUID to register face for"
          },
          "file": {
            "type": "string",
            "format": "binary",
            "description": "Face image file (JPEG/PNG, multipart upload)"
          }
        },
        "required": ["student_id", "file"]
      },
      "annotations": {
        "httpMethod": "POST",
        "endpoint": "/api/v1/recognition/register-face",
        "contentType": "multipart/form-data",
        "auth": true,
        "authLevel": "active_user",
        "idempotent": false,
        "readOnly": false
      },
      "returns": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "student_id": { "type": "string" }
        }
      },
      "errors": [
        { "code": 409, "message": "Face already registered to another student (duplicate detection)" },
        { "code": 400, "message": "No face detected in image" }
      ]
    },
    {
      "name": "recognition_recognize",
      "description": "Recognize faces in a camera frame. Returns matched students and unrecognized bounding boxes. Auto-marks students present if a scanning session is active.",
      "category": "recognition",
      "inputSchema": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "Camera frame image (JPEG, multipart upload)"
          }
        },
        "required": ["file"]
      },
      "annotations": {
        "httpMethod": "POST",
        "endpoint": "/api/v1/recognition/recognize",
        "contentType": "multipart/form-data",
        "auth": true,
        "authLevel": "active_user",
        "idempotent": true,
        "readOnly": false
      },
      "returns": {
        "type": "object",
        "properties": {
          "match": { "type": "boolean" },
          "matches": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "student_id": { "type": "string" },
                "distance": { "type": "number" },
                "metadata": { "type": "object" },
                "bbox": { "type": "array", "items": { "type": "number" } }
              }
            }
          },
          "unrecognized": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "bbox": { "type": "array", "items": { "type": "number" } }
              }
            }
          },
          "frame_size": { "type": "array", "items": { "type": "integer" } }
        }
      }
    },
